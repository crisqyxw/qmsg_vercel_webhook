{
  "functions": {
    "api/webhook.js": {
      "maxDuration": 10
    },
    "api/status.js": {
      "maxDuration": 5
    }
  },
  "rewrites": [
    {
      "source": "/webhook",
      "destination": "/api/webhook.js"
    },
    {
      "source": "/api/status",
      "destination": "/api/status.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}